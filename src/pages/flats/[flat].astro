---
export const prerender = true;

import { flats } from "#data/flats.ts";
import Layout from "#layouts/Layout.astro";
import UnitInfo from "#components/flats/UnitInfo.astro";
import Params from "#components/flats/Params.astro";
import ShortAbout from "#components/flats/ShortAbout.astro";
import Gallery from "#components/Gallery.astro";
import Contact from "#components/Contact.astro";

import img1 from "#assets/Image_galllery_asset_placeholder_wide.jpg";


export function getStaticPaths() {
	return flats.map((flat) => ({
		params: { flat: flat.id.toString() },
		props: { flat },
	}));
}

const { flat } = Astro.props;

const images = [
	{src: img1, alt: "Obrázek 1"},
	{src: img1, alt: "Obrázek 2"},
	{src: img1, alt: "Obrázek 3"},
	{src: img1, alt: "Obrázek 4"},
	{src: img1, alt: "Obrázek 5"},
	{src: img1, alt: "Obrázek 6"},
	{src: img1, alt: "Obrázek 7"},
	{src: img1, alt: "Obrázek 8"},
	{src: img1, alt: "Obrázek 9"},
]
---

<Layout>
	<UnitInfo flat={flat} />
	<Params flat={flat} />
	<ShortAbout />
	<Gallery images={images} showButton={false} />
	<Contact />
</Layout>
