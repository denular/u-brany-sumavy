---
import { Image } from "astro:assets";
import logo from "../../assets/BranaUSumavyApartmany_Logo_Color_RGB.svg";
import LinkButton from "../../components/LinkButton.astro";
import LocaleButton from "../../components/LocaleButton.astro";
import Menu from "../../components/Menu.astro";
---

<header
	class="bg-white px-15 py-5 sticky top-0 w-full z-300 flex flex-col gap-10 shadow-md"
>
	<div
		class="h-10 grid grid-flow-col auto-cols-max gap-5 justify-between items-center"
	>
		<a href="/">
			<Image src={logo} alt="Logo" class="w-[30vw]" />
		</a>
		<div
			id="settings"
			class="grid grid-flow-col auto-cols-max gap-5 items-center"
		>
			<LocaleButton classList="hover-dark invisible" />
			<LinkButton
				text="Nabídka bytů"
				href="#Flats"
				classList="hover-dark"
			/>
			<LinkButton
				text="Kontaktujte nás"
				href="#Contact"
				classList="hover-dark"
			/>
		</div>
	</div>
	<Menu id="headerMenu" />
</header>
