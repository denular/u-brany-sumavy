---
import { Image } from "astro:assets";
import buildRect from "#assets/Image_asset_764x535_2x.jpg";
import buildSquare from "#assets/Image_asset_764x700_2x.jpg";
import map from "#assets/mapa.jpg";
import LinkButton from "#components/LinkButton.astro";
---

<section id="Directions" class="mt-25 flex flex-col gap-25 items-center">
	<div class="mx-[4vw] flex flex-col gap-20">
		<h1 class="lg:ml-[8%]">LOKALITA</h1>
		<div class="flex flex-col gap-5 lg:grid lg:gap-0 grid-flow-col grid-cols-[55%_45%] items-center">
			<Image
				src={buildRect}
				alt="Pohled na objekt"
				class="max-h-[calc(80vh-144px)] aspect-video object-cover"
			/>
			<div class="lg:px-[25%] text-justify">
				<h3 class="text-left">VAŠE MÍSTO NA ŠUMAVĚ</h3>
				<p>
					Apartmány U Brány Šumavy se nacházejí v klidné lokalitě na
					dosah šumavské přírody, s výbornou dostupností do okolních
					obcí i sportovních areálů.
				</p>
			</div>
		</div>
	</div>
	<hr class="w-[80vw] max-w-lg border-green" />
	<div class="flex flex-col items-center gap-15">
		SEM PŘIJDE BROŽURA
		<LinkButton
		text="Nabídka apartmánů"
		href="#Flats"
		classList="hover-dark text-sm"
		/>
	</div>
</section>
