---
import { Image } from 'astro:assets'
import aboutFirst from '#assets/about_1.jpg'
import aboutSecond from '#assets/about_2.jpg'
import LinkButton from '#components/LinkButton.astro'
import type { ArgumentsData } from '#types/arguments.ts'

interface Props {
	argumentsData: ArgumentsData
}

const { argumentsData } = Astro.props
---

<section id="About" class="mx-[4vw] mt-25 flex flex-col gap-20 items-center">
	<h1 class="lg:ml-[8%] self-stretch">O PROJEKTU</h1>
	<div
		class="flex flex-col gap-5 lg:grid lg:gap-0 grid-flow-col grid-cols-[55%_45%] items-center"
	>
		<Image
			src={aboutFirst}
			alt="Pohled na objekt"
			class="max-h-[calc(80vh-144px)] aspect-video object-cover"
		/>
		<div class="lg:px-[20%] text-justify">
			<h3 class="text-left">{argumentsData.about.title}</h3>
			<p>
				{argumentsData.about.text}
			</p>
		</div>
	</div>
	<div
		class="text-justify flex flex-col-reverse gap-5 lg:grid lg:gap-0 grid-flow-col grid-cols-[45%_55%] items-center"
	>
		<div class="lg:px-[20%]">
			<h3 class="text-left">{argumentsData.aboutLocality.title}</h3>
			<p>
				{argumentsData.aboutLocality.text}
			</p>
		</div>
		<Image
			src={aboutSecond}
			alt="Pohled na objekt"
			class="max-h-[calc(80vh-144px)] aspect-video object-cover"
		/>
	</div>
	<LinkButton
		text="Domluvit prohlídku"
		href="#Contact"
		classList="hover-dark object-cover"
	/>
</section>
